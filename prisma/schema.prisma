generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId           Int       @id @default(autoincrement()) @map("user_id")
  gmail            String?   @unique @db.VarChar(100)
  passwordHash     String?   @map("password_hash") @db.VarChar(255)
  username         String    @unique @db.VarChar(50)
  age              Int?
  gender           String?   @db.VarChar(10)
  isOnline         Boolean   @default(false) @map("is_online")
  isGuest          Boolean   @default(false) @map("is_guest")
  receivedMessages Message[] @relation("Receiver")
  sentMessages     Message[] @relation("Sender")
  sentGlobalMessages GlobalMessage[]
  friendshipsOne   Friendship[] @relation("FriendshipsUserOne")
  friendshipsTwo   Friendship[] @relation("FriendshipsUserTwo")
  sentFriendRequests FriendRequest[] @relation("FriendRequestsSender")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestsReceiver")
  messageReactions MessageReaction[]
  blockedUsers     UserBlock[] @relation("UserBlocksBlocker")
  blockedByUsers   UserBlock[] @relation("UserBlocksBlocked")
  readStatesOwned  ConversationReadState[] @relation("ReadStatesUser")
  readStatesOther  ConversationReadState[] @relation("ReadStatesOtherUser")

  @@map("Users")
  @@index([isOnline])
}

model Friendship {
  id        Int      @id @default(autoincrement())
  userId1   Int      @map("user_id1")
  userId2   Int      @map("user_id2")
  createdAt DateTime @default(now()) @map("created_at")
  userOne   User     @relation("FriendshipsUserOne", fields: [userId1], references: [userId], onDelete: Cascade)
  userTwo   User     @relation("FriendshipsUserTwo", fields: [userId2], references: [userId], onDelete: Cascade)

  @@unique([userId1, userId2])
  @@index([userId1])
  @@index([userId2])
  @@map("Friendships")
}

model FriendRequest {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int      @map("receiver_id")
  status     String   @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  respondedAt DateTime? @map("responded_at")
  sender     User     @relation("FriendRequestsSender", fields: [senderId], references: [userId], onDelete: Cascade)
  receiver   User     @relation("FriendRequestsReceiver", fields: [receiverId], references: [userId], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("FriendRequests")
}

model Message {
  msgId          Int       @id @default(autoincrement()) @map("msg_id")
  senderId       Int       @map("sender_id")
  receiverId     Int       @map("receiver_id")
  conversationId String?   @db.VarChar(64) @map("conversation_id")
  replyToId      Int?      @map("reply_to_id")
  message        String
  editedAt       DateTime? @map("edited_at")
  deletedAt      DateTime? @map("deleted_at")
  timestamp      DateTime  @default(now())
  receiver       User      @relation("Receiver", fields: [receiverId], references: [userId])
  sender         User      @relation("Sender", fields: [senderId], references: [userId])
  replyTo        Message?  @relation("MessageReplies", fields: [replyToId], references: [msgId], onDelete: SetNull)
  replies        Message[] @relation("MessageReplies")

  attachments Attachment[]
  reactions   MessageReaction[]
  @@map("Messages")
  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
  @@index([timestamp])
  @@index([replyToId])
  @@index([conversationId, timestamp, msgId])
  @@unique([timestamp, msgId], name: "timestamp_msgId")
}

model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  userId    Int      @map("user_id")
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")
  message   Message  @relation(fields: [messageId], references: [msgId], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@map("MessageReactions")
}

model Attachment {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  url       String
  filename  String
  fileType  String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [msgId], onDelete: Cascade)

  @@index([messageId])
  @@map("Attachments")
}

model GlobalMessage {
  id        Int      @id @default(autoincrement())
  senderId  Int      @map("sender_id")
  message   String
  timestamp DateTime @default(now())
  sender    User     @relation(fields: [senderId], references: [userId])

  @@map("GlobalMessages")
  @@index([timestamp])
}

model ConversationReadState {
  userId         Int      @map("user_id")
  otherUserId    Int      @map("other_user_id")
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  user           User     @relation("ReadStatesUser", fields: [userId], references: [userId], onDelete: Cascade)
  otherUser      User     @relation("ReadStatesOtherUser", fields: [otherUserId], references: [userId], onDelete: Cascade)

  @@id([userId, otherUserId])
  @@index([userId])
  @@map("ConversationReadStates")
}

model UserBlock {
  id        Int      @id @default(autoincrement())
  blockerId Int      @map("blocker_id")
  blockedId Int      @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")
  blocker   User     @relation("UserBlocksBlocker", fields: [blockerId], references: [userId], onDelete: Cascade)
  blocked   User     @relation("UserBlocksBlocked", fields: [blockedId], references: [userId], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("UserBlocks")
}
